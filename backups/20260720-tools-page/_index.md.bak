users = [
  "经常使用链上钱包的用户",
  "参与 DeFi、NFT 或跨链操作的用户",
  "需要定期检查授权风险的用户",
]
features = [
  "授权检查和撤销",
  "私钥、助记词和硬件钱包管理",
  "钓鱼链接和合约交互风险识别",
]
steps = [
  "定期检查钱包授权。",
  "重要资产使用冷钱包或硬件钱包隔离。",
  "交互前确认域名、合约地址和授权范围。",
]
notes = [
  "不要把助记词输入任何网页。",
  "不要盲目签名不理解的消息。",
  "高价值资产应和日常交互钱包分离。",
]
