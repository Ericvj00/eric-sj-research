{{ define "main" }}
{{ $recommended := .Params.recommended_tools | default slice }}
{{ $research := .Params.research_tools | default slice }}

<section class="section-hero tools-hero toolbox-hero">
  <div class="container section-hero-grid">
    <div>
      <p class="eyebrow">{{ .Params.section_label | default "Tools" }}</p>
      <h1>{{ .Params.hero_title | default .Title }}</h1>
    </div>
    <div class="section-hero-copy">
      {{ with .Params.hero_description }}<p>{{ . }}</p>{{ end }}
    </div>
  </div>
</section>

<section class="section toolbox-section recommended-tools-section">
  <div class="container">
    <div class="section-heading">
      <p class="eyebrow">Recommended</p>
      <h2>🔥 推荐工具</h2>
    </div>

    <div class="recommended-tools-grid">
      {{ range $tool := $recommended }}
        <article class="recommend-tool-card">
          <div class="tool-card-body">
            <h3>{{ $tool.title }}</h3>
            {{ with $tool.description }}<p class="tool-card-description">{{ . }}</p>{{ end }}

            {{ with $tool.coverage }}
              <div class="tool-card-block">
                <h4>{{ $tool.coverage_title | default "覆盖" }}</h4>
                <ul class="tool-chip-list">
                  {{ range . }}<li>{{ . }}</li>{{ end }}
                </ul>
              </div>
            {{ end }}

            {{ with $tool.scenes }}
              <div class="tool-card-block">
                <h4>{{ $tool.scenes_title | default "适合场景" }}</h4>
                <ul>
                  {{ range . }}<li>{{ . }}</li>{{ end }}
                </ul>
              </div>
            {{ end }}

            {{ with $tool.features }}
              <div class="tool-card-block">
                <h4>{{ $tool.features_title | default "特点" }}</h4>
                <ul>
                  {{ range . }}<li>✓ {{ . }}</li>{{ end }}
                </ul>
              </div>
            {{ end }}
          </div>

          <a class="tool-primary-link" href="{{ $tool.url }}" target="_blank" rel="noopener noreferrer">{{ $tool.button_label }}</a>
        </article>
      {{ end }}
    </div>
  </div>
</section>

<section class="section toolbox-section research-tools-section">
  <div class="container">
    <div class="section-heading research-tools-heading">
      <div>
        <p class="eyebrow">Research Data</p>
        <h2>📊 研究数据工具</h2>
      </div>
      <p>这些工具主要用于 Eric SJ 日常研究、数据查询和行业分析。</p>
    </div>

    <div class="research-tools-list">
      {{ range $research }}
        <article class="research-tool-row">
          <div>
            <h3>{{ .title }}</h3>
            {{ with .description }}<p class="research-tool-description">{{ . }}</p>{{ end }}
          </div>
          <div class="research-tool-meta">
            <p><strong>用途：</strong>{{ .usage }}</p>
            <p><strong>适合：</strong>{{ delimit .suitable " / " }}</p>
          </div>
          <a class="tool-secondary-link" href="{{ .url }}" target="_blank" rel="noopener noreferrer">访问网站 →</a>
        </article>
      {{ end }}
    </div>
  </div>
</section>

{{ with .Content }}
<section class="section toolbox-note-section">
  <div class="container">
    <div class="toolbox-note">{{ . }}</div>
  </div>
</section>
{{ end }}
{{ end }}
