{{- $pages := where .Site.RegularPages "Section" "in" (slice "articles" "web3" "stocks" "guides") -}}
{{- $items := slice -}}
{{- range $pages.ByDate.Reverse -}}
  {{- if not .Draft -}}
    {{- $items = $items | append (dict
      "title" .Title
      "url" .RelPermalink
      "summary" (.Params.summary | default .Params.description | default .Summary | plainify)
      "tags" (.Params.tags | default slice)
      "categories" (slice (partial "category-label.html" .))
      "content" (.Plain | plainify)
      "date" (.Date.Format "2006-01-02")
    ) -}}
  {{- end -}}
{{- end -}}
{{- $items | jsonify -}}
